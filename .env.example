APP_ENV=production
PORT=8080
JWT_SECRET=change-me-to-a-long-random-secret
DEV_SMS_CODE=1234
ACCESS_TOKEN_HOURS=24
REFRESH_TOKEN_HOURS=720

# PostgreSQL for Railway
DB_DRIVER=postgres
DATABASE_URL=postgresql://postgres:password@localhost:5432/usto?sslmode=require

